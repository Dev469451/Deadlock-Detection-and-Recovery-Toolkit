# Deadlock Detection Logic [cite: 242]
def check_deadlock(total_vec, alloc_mat, req_mat):
    n, m = alloc_mat.shape [cite: 242]
    work = total_vec - alloc_mat.sum(axis=0) [cite: 242]
    finish = np.array([False] * n) [cite: 242]
    safe_seq = [] [cite: 242]
    
    changed = True [cite: 242]
    while changed:
        changed = False [cite: 242]
        for i in range(n):
            if not finish[i] and np.all(req_mat[i] <= work):
                work = work + alloc_mat[i] [cite: 242]
                finish[i] = True [cite: 242]
                safe_seq.append(f"P{i}") [cite: 242]
                changed = True [cite: 242]
                
    deadlocked = [f"P{i}" for i in range(n) if not finish[i]] [cite: 242]
    is_deadlock = len(deadlocked) > 0 [cite: 242]
    return is_deadlock, safe_seq, deadlocked, work [cite: 242]

